# FIA Gateway – Environment Variables
# Copy to .env and fill in values

# LLM (Claude-first – Anthropic är primär LLM-leverantör)
ANTHROPIC_API_KEY=               # Claude Opus 4.6 (primär) + Sonnet 4.6 (volym)
GEMINI_API_KEY=                  # Google AI Studio (enbart Nano Banana 2 bildgenerering)
SERPER_API_KEY=                  # Serper.dev API key (Google search results)

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Supabase
SUPABASE_URL=                    # https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=       # Server-side key (never in frontend)
SUPABASE_ANON_KEY=               # Public key (used by Dashboard)

# Google Workspace
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=  # Absolute path to service account JSON (for gws CLI)
GOOGLE_WORKSPACE_CLI_IMPERSONATED_USER= # e.g. fia@forefront.se
GWORKSPACE_CREDS_DIR=                   # Directory for @alanse MCP server OAuth credentials

# MCP / Integrations
HUBSPOT_API_KEY=
LINKEDIN_ACCESS_TOKEN=
GA4_CREDENTIALS_PATH=
BUFFER_ACCESS_TOKEN=

# CLI
FIA_CLI_TOKEN=                   # Lokal auth-token för CLI (bypass JWT)

# System
NODE_ENV=production
LOG_LEVEL=info
LOG_DIR=./logs
KNOWLEDGE_DIR=./knowledge
GATEWAY_API_PORT=3001            # Internal REST API port (not exposed)

# Queue
QUEUE_MAX_CONCURRENCY=3          # Max parallel agent tasks

# Cost
USD_TO_SEK=10.5                  # Fixed USD→SEK exchange rate
