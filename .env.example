# FIA Gateway – Environment Variables
# Copy to .env and fill in values

# LLM
ANTHROPIC_API_KEY=               # Claude Opus/Sonnet
GEMINI_API_KEY=                  # Google AI Studio (Gemini Pro/Flash/Nano Banana 2)
GOOGLE_SEARCH_API_KEY=           # Custom Search JSON API
GOOGLE_SEARCH_CX=               # Custom Search Engine ID

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Supabase
SUPABASE_URL=                    # https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=       # Server-side key (never in frontend)
SUPABASE_ANON_KEY=               # Public key (used by Dashboard)

# Google Workspace CLI
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=  # Absolute path to credentials.json

# MCP / Integrations
WORDPRESS_URL=
WORDPRESS_API_KEY=
HUBSPOT_API_KEY=
LINKEDIN_ACCESS_TOKEN=
GA4_CREDENTIALS_PATH=
BUFFER_ACCESS_TOKEN=

# System
NODE_ENV=production
LOG_LEVEL=info
LOG_DIR=./logs
KNOWLEDGE_DIR=./knowledge
GATEWAY_API_PORT=3001            # Internal REST API port (not exposed)
